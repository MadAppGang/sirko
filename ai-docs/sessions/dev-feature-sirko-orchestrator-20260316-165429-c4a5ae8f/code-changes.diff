+
+    await new Promise((r) => setTimeout(r, 20))
+
+    expect(sent).toContain(1)
+    expect(sent).toContain(2)
+  })
+
+  it('forces flush when maxBufferChars exceeded', async () => {
+    const sent: string[] = []
+
+    const streamer = new OutputStreamer({
+      debounceMs: 5000,
+      maxBufferChars: 10,
+      onSend: async ({ text }) => {
+        sent.push(text)
