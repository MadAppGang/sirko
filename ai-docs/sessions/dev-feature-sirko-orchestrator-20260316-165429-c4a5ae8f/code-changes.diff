+
+function makePane(overrides: Partial<PaneState> = {}): PaneState {
+  return {
+    paneId: '%1',
+    sessionId: '$1',
+    windowId: '@1',
+    tool: 'claude-code',
+    pid: 1234,
+    status: 'running',
