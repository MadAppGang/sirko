+      onSendFile: async () => {},
+    })
+
+    streamer.push(1, 'x'.repeat(15)) // exceeds maxBufferChars=10
+
+    await new Promise((r) => setTimeout(r, 20))
+
+    expect(sent.length).toBe(1)
